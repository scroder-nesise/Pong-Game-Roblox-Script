            rightScoreVal = tonumber(parts[2]) or 0
            rightScore.Text = tostring(rightScoreVal)
        end
        if parts[3] then
            local d = parts[3]:match("^%s*(.-)%s*$") -- trim whitespace
            if DIFFICULTY_PRESETS[d] then
                applyDifficulty(d)
            end
        end
        showPing("Loaded!", Vector2.new(PLAY_AREA_SIZE.X/2, areaSize.Y/2))
    end)

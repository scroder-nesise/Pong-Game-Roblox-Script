local function canAfford(cost) return leftScoreVal >= cost end

local function spendPoints(cost)
    leftScoreVal = math.max(0, leftScoreVal - cost)
    leftScore.Text = tostring(leftScoreVal)
    shopTitle.Text = "🛒 Shop  (your pts: " .. leftScoreVal .. ")"
end

local function flashMsg(text, color)
    local msg = Instance.new("TextLabel", shopPanel)
    msg.Size = UDim2.new(1, -12, 0, 22)
    msg.Position = UDim2.new(0, 6, 1, -28)
    msg.BackgroundTransparency = 0.4
    msg.BackgroundColor3 = Color3.fromRGB(30, 30, 36)
    msg.TextColor3 = color or Color3.fromRGB(200, 200, 200)
    msg.Font = Enum.Font.SourceSansSemibold
    msg.TextScaled = true
    msg.Text = text
    msg.ZIndex = 22
    Instance.new("UICorner", msg).CornerRadius = UDim.new(0, 6)
    task.spawn(function()
        task.wait(1.8)
        if msg and msg.Parent then pcall(function() msg:Destroy() end) end
    end)
end

local function addEffect(id, duration, revertFn)
    table.insert(shopActiveEffects, { id = id, endsAt = tick() + duration, revert = revertFn })
end

local function applyShopItem(item)
    if not canAfford(item.cost) then
        flashMsg("Not enough points!", Color3.fromRGB(255, 120, 120)); return
    end
    spendPoints(item.cost)

    if item.id == "SlowBall" then
        local m = item.mult
        ballGlobalMultiplier *= m
        addEffect(item.id, item.duration, function() ballGlobalMultiplier /= m end)
        flashMsg("Slow Ball active!", Color3.fromRGB(120, 200, 255))

    elseif item.id == "EnlargePaddle" then
        local newH = math.floor(currentPaddleHeights.left * item.scale)
        currentPaddleHeights.left = newH
        leftPaddle.Size = UDim2.new(0, PADDLE_W, 0, newH)
        setPaddleY(leftPaddle, getPaddleY(leftPaddle))
        addEffect(item.id, item.duration, function()
            currentPaddleHeights.left = PADDLE_H
            leftPaddle.Size = UDim2.new(0, PADDLE_W, 0, PADDLE_H)
        end)
        flashMsg("Paddle enlarged!", Color3.fromRGB(160, 230, 140))

    elseif item.id == "ShrinkOpponent" then
        local newH = math.max(28, math.floor(currentPaddleHeights.right * item.scale))
        currentPaddleHeights.right = newH
        rightPaddle.Size = UDim2.new(0, PADDLE_W, 0, newH)
        setPaddleY(rightPaddle, getPaddleY(rightPaddle))
        addEffect(item.id, item.duration, function()
            currentPaddleHeights.right = PADDLE_H
            rightPaddle.Size = UDim2.new(0, PADDLE_W, 0, PADDLE_H)
        end)
        flashMsg("Opponent shrunk!", Color3.fromRGB(255, 170, 120))

    elseif item.id == "DoublePoints" then
        doublePointsActive = true
        addEffect(item.id, item.duration, function() doublePointsActive = false end)
        flashMsg("Double Points active!", Color3.fromRGB(255, 215, 0))

    elseif item.id == "ReverseControls" then
        reverseControlsActive = true
        addEffect(item.id, item.duration, function() reverseControlsActive = false end)
        flashMsg("Bot reversed!", Color3.fromRGB(255, 120, 220))

    elseif item.id == "GhostBall" then
        ghostBallActive = true
        ball.BackgroundTransparency = 0.55
        ball.BackgroundColor3 = Color3.fromRGB(200, 240, 255)
        addEffect(item.id, item.duration, function()
            ghostBallActive = false
            ball.BackgroundTransparency = 0
            ball.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
        end)
        flashMsg("Ghost Ball active!", Color3.fromRGB(180, 240, 255))

    elseif item.id == "TurboBall" then
        local m = 1.5
        ballGlobalMultiplier *= m
        addEffect(item.id, item.duration, function() ballGlobalMultiplier /= m end)
        flashMsg("Turbo Ball active!", Color3.fromRGB(255, 160, 50))

    elseif item.id == "Shield" then
        shieldActive = true
        flashMsg("Shield ready!", Color3.fromRGB(100, 220, 255))
    end
end

local function updateShopEffects()
    local now = tick()
    for i = #shopActiveEffects, 1, -1 do
        local e = shopActiveEffects[i]
        if now >= e.endsAt then
            pcall(e.revert)
            table.remove(shopActiveEffects, i)
        end
    end
end


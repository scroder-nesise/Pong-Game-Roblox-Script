local function getAreaSize()
    local s = playFrame.AbsoluteSize
    return (s.X == 0 and s.Y == 0) and PLAY_AREA_SIZE or Vector2.new(s.X, s.Y)
end

local function setBallPos(pos)
    local s = getAreaSize()
    ball.Position = UDim2.new(pos.X/s.X, 0, pos.Y/s.Y, 0)
end

local function setPaddleY(p, y)
    local s = getAreaSize()
    p.Position = UDim2.new(p.Position.X.Scale, p.Position.X.Offset, 0, math.clamp(y, 0, s.Y - p.AbsoluteSize.Y))
end

local function getPaddleY(p) return p.Position.Y.Offset end

local function paddleRect(p)
    local px = p.AbsolutePosition.X - playFrame.AbsolutePosition.X
    return px, getPaddleY(p), p.AbsoluteSize.X, p.AbsoluteSize.Y
end


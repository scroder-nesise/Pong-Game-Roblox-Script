local function showPing(text, pos)
    if not alive then return end
    local s = Instance.new("TextLabel", playFrame)
    s.Size = UDim2.new(0, 140, 0, 36)
    s.AnchorPoint = Vector2.new(0.5, 0.5)
    local sz = getAreaSize()
    local x, y = pos.X/sz.X, pos.Y/sz.Y
    s.Position = UDim2.new(x, 0, y, 0)
    s.BackgroundTransparency = 0.5
    s.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    s.TextColor3 = Color3.new(1, 1, 1)
    s.Font = Enum.Font.SourceSansSemibold
    s.TextScaled = true
    s.Text = text
    s.BorderSizePixel = 0
    s.ZIndex = 10
    s.TextTransparency = 0.5
    task.spawn(function()
        local total, elapsed = 0.6, 0
        while elapsed < total and s and s.Parent and alive do
            local dt = RunService.RenderStepped:Wait()
            elapsed += dt
            local t = math.clamp(elapsed/total, 0, 1)
            s.Position = UDim2.new(x, 0, y, -18*t)
            s.TextTransparency = 0.5 + 0.5*t
            s.BackgroundTransparency = 0.5 + 0.5*t
        end
        if s and s.Parent then pcall(function() s:Destroy() end) end
    end)
end


-- Ping visual: transient label with 50% opacity initially, then fade
local function showPing(text, atPosition)
    if not alive then return end
    local s = Instance.new("TextLabel", playFrame)
    s.Size = UDim2.new(0, 140, 0, 36)
    s.AnchorPoint = Vector2.new(0.5, 0.5)
    local p = atPosition or (getAreaSize() / 2)
    local x = p.X / getAreaSize().X
    local y = p.Y / getAreaSize().Y
    s.Position = UDim2.new(x, 0, y, 0)
    s.BackgroundTransparency = 0.5
    s.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    s.TextColor3 = Color3.new(1,1,1)
    s.Font = Enum.Font.SourceSansSemibold
    s.TextScaled = true
    s.Text = text or "Ping!"
    s.BorderSizePixel = 0
    s.ZIndex = 10
    s.TextTransparency = 0.5 -- 50% opacity (semi-transparent text)

    spawn(function()
        local total = 0.6
        local dt = 0
        while dt < total and s and s.Parent and alive do
            local step = RunService.RenderStepped:Wait()
            dt = dt + step
            s.Position = UDim2.new(x, 0, y, -18 * (dt / total))
            local t = math.clamp(dt / total, 0, 1)
            s.TextTransparency = 0.5 + 0.5 * t
            s.BackgroundTransparency = 0.5 + 0.5 * t
        end
        if s and s.Parent then pcall(function() s:Destroy() end) end
    end)
end

-- Boost state
local activeBoosts = {
    left = {mult = 1, endsAt = 0},
    right = {mult = 1, endsAt = 0},
}

local function applyBoost(side, boostType)
    if side ~= "left" and side ~= "right" then return end
    local info = BOOSTS[boostType]
    if not info then return end
    local now = tick()
    activeBoosts[side].mult = info.mult
    activeBoosts[side].endsAt = now + BOOST_DURATION

    -- Visual indicator near paddle
    local label = Instance.new("TextLabel", playFrame)
    label.Name = side .. "_BoostLabel"
    label.Size = UDim2.new(0, 140, 0, 26)
    if side == "left" then
        label.Position = UDim2.new(0, 110, 0, 8)
    else
        label.Position = UDim2.new(1, -250, 0, 8)
    end
    label.BackgroundTransparency = 0.2
    label.BackgroundColor3 = info.color
    label.TextColor3 = Color3.new(1,1,1)
    label.Font = Enum.Font.SourceSansSemibold
    label.TextScaled = true
    label.Text = info.text
    local lblCorner = Instance.new("UICorner", label); lblCorner.CornerRadius = UDim.new(0,6)

    spawn(function()
        local remaining = activeBoosts[side].endsAt - tick()
        while remaining > 0 and alive do
            wait(0.2)
            remaining = activeBoosts[side].endsAt - tick()
        end
        if label and label.Parent then pcall(function() label:Destroy() end) end
    end)
end

local function updateBoosts()
    local now = tick()
    for side,st in pairs(activeBoosts) do
        if st.endsAt > 0 and now >= st.endsAt then
            st.mult = 1
            st.endsAt = 0
            local name = side .. "_BoostLabel"
            local existing = playFrame:FindFirstChild(name)
            if existing then pcall(function() existing:Destroy() end) end
        end
    end
end

-- ------ SHOP LOGIC ------

local shopActiveEffects = {} -- track active temporary shop effects, to revert cleanly
-- structure: { id = { endsAt = time, revert = fn } }

local function canAfford(cost)
    return leftScoreVal >= cost
end

local function spendPoints(cost)
    leftScoreVal = math.max(0, leftScoreVal - cost)
    leftScore.Text = tostring(leftScoreVal)
end

local function flashShopMessage(text, color)
    color = color or Color3.fromRGB(200,200,200)
    local msg = Instance.new("TextLabel", shopPanel)
    msg.Size = UDim2.new(1, -12, 0, 22)
    msg.Position = UDim2.new(0, 6, 1, -28)
    msg.BackgroundTransparency = 0.4
    msg.BackgroundColor3 = Color3.fromRGB(30,30,36)
    msg.TextColor3 = color
    msg.Font = Enum.Font.SourceSansSemibold
    msg.TextScaled = true
    msg.Text = text
    local c = Instance.new("UICorner", msg); c.CornerRadius = UDim.new(0,6)
    spawn(function()
        wait(1.6)
        if msg and msg.Parent then pcall(function() msg:Destroy() end) end
    end)
end

-- Apply a shop item (only player can buy; effects mostly affect player or opponent)
local function applyShopItem(item)
    if not item then return end
    if not canAfford(item.cost) then
        flashShopMessage("Not enough points!", Color3.fromRGB(255,120,120))
        return
    end

    spendPoints(item.cost)

    local now = tick()
    if item.id == "SlowBall" then
        -- multiply ballGlobalMultiplier
        local m = item.mult
        ballGlobalMultiplier = ballGlobalMultiplier * m
        -- schedule revert
        table.insert(shopActiveEffects, { id = item.id, endsAt = now + item.duration, revert = function()
            ballGlobalMultiplier = ballGlobalMultiplier / m
        end })
        flashShopMessage("Slow Ball bought!", Color3.fromRGB(120,200,255))
    elseif item.id == "EnlargePaddle" then
        local scale = item.scale
        -- apply to left paddle height
        local prev = currentPaddleHeights.left
        local newH = math.floor(prev * scale)
        currentPaddleHeights.left = newH
        leftPaddle.Size = UDim2.new(0, PADDLE_W, 0, newH)
        -- clamp position to keep paddle in bounds
        setPaddleYPixels(leftPaddle, math.clamp(getPaddleYPixels(leftPaddle), 0, getAreaSize().Y - newH))

        table.insert(shopActiveEffects, { id = item.id, endsAt = now + item.duration, revert = function()
            currentPaddleHeights.left = PADDLE_H
            leftPaddle.Size = UDim2.new(0, PADDLE_W, 0, PADDLE_H)
            setPaddleYPixels(leftPaddle, math.clamp(getPaddleYPixels(leftPaddle), 0, getAreaSize().Y - PADDLE_H))
        end })
        flashShopMessage("Paddle enlarged!", Color3.fromRGB(160,230,140))
    elseif item.id == "ShrinkOpponent" then
        local scale = item.scale
        local prev = currentPaddleHeights.right
        local newH = math.max(28, math.floor(prev * scale))
        currentPaddleHeights.right = newH
        rightPaddle.Size = UDim2.new(0, PADDLE_W, 0, newH)
        setPaddleYPixels(rightPaddle, math.clamp(getPaddleYPixels(rightPaddle), 0, getAreaSize().Y - newH))

        table.insert(shopActiveEffects, { id = item.id, endsAt = now + item.duration, revert = function()
            currentPaddleHeights.right = PADDLE_H
            rightPaddle.Size = UDim2.new(0, PADDLE_W, 0, PADDLE_H)
            setPaddleYPixels(rightPaddle, math.clamp(getPaddleYPixels(rightPaddle), 0, getAreaSize().Y - PADDLE_H))
        end })
        flashShopMessage("Opponent shrunk!", Color3.fromRGB(255,170,120))
    end
end

-- shop active effects updater (reverts when time done)
local function updateShopEffects()
    local now = tick()
    for i = #shopActiveEffects, 1, -1 do
        local e = shopActiveEffects[i]
        if now >= e.endsAt then
            if e.revert then
                pcall(e.revert)
            end
            table.remove(shopActiveEffects, i)
        end
    end
end


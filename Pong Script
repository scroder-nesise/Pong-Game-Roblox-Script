-- Booster management
local boosters = {} -- array of {frame, type, posPixels, createdAt}

local function createBooster()
    if not alive then return end
    local size = getAreaSize()
    local margin = 80
    if size.X < margin*2 then margin = 20 end
    local x = math.random(margin, math.max(margin+1, size.X - margin))
    local y = math.random(40, math.max(41, size.Y - 40))
    local pos = Vector2.new(x, y)

    local btype = (math.random() < 0.5) and "SpeedUp" or "SlowDown"

    local frame = Instance.new("Frame", playFrame)
    frame.Name = "Booster"
    frame.Size = UDim2.new(0, BOOST_RADIUS*2, 0, BOOST_RADIUS*2)
    frame.AnchorPoint = Vector2.new(0.5, 0.5)
    frame.Position = UDim2.new(pos.X / size.X, 0, pos.Y / size.Y, 0)
    frame.BackgroundColor3 = BOOSTS[btype].color
    frame.BorderSizePixel = 0
    local corner = Instance.new("UICorner", frame)
    corner.CornerRadius = UDim.new(1, 0)
    local pulse = Instance.new("UIStroke", frame)
    pulse.Color = Color3.fromRGB(255,255,255)
    pulse.Transparency = 0.75
    pulse.Thickness = 1

    local createdAt = tick()
    table.insert(boosters, {frame = frame, type = btype, pos = pos, createdAt = createdAt})
    -- auto-despawn
    spawn(function()
        local t0 = tick()
        while alive and tick() - t0 < BOOST_LIFETIME do
            wait(0.5)
        end
        for i=#boosters,1,-1 do
            if boosters[i].frame == frame then
                if frame and frame.Parent then pcall(function() frame:Destroy() end) end
                table.remove(boosters, i)
            end
        end
    end)
end

-- Booster spawner thread
spawn(function()
    while alive do
        local t = math.random(BOOST_SPAWN_MIN, BOOST_SPAWN_MAX)
        local waited = 0
        while alive and waited < t do
            wait(0.5)
            waited = waited + 0.5
        end
        if not alive then break end
        createBooster()
    end
end)

-- Utility: safe paddle rect pixels
local function paddleRectPixels(paddle)
    local px = paddle.AbsolutePosition.X - playFrame.AbsolutePosition.X
    local py = getPaddleYPixels(paddle)
    return px, py, paddle.AbsoluteSize.X, paddle.AbsoluteSize.Y
end

-- Improved paddle hit reflection: uses hit point to compute a reliable outgoing direction
local function reflectFromPaddle(side, px, py, pw, ph)
    -- compute normalized hit offset (-1 top .. 0 center .. 1 bottom)
    local hitOffset = (ballPos.Y - (py + ph/2)) / (ph/2)
    hitOffset = math.clamp(hitOffset, -1, 1)
    local dirX = (side == "left") and 1 or -1
    local dir = Vector2.new(dirX, hitOffset)
    -- Ensure the horizontal component is not too small to avoid sliding
    if math.abs(dir.X) < 0.5 then
        dir = Vector2.new(0.5 * dirX, dir.Y)
    end
    return dir.unit
end

-- AI state
local aiReactionTimer = 0
local aiTargetY = nil

-- Game loop
local lastTime = tick()
local renderConn
renderConn = RunService.RenderStepped:Connect(function()
    if not alive then
        if renderConn then renderConn:Disconnect() end
        return
    end

    local now = tick()
    local dt = math.clamp(now - lastTime, 0, 0.05)
    lastTime = now

    areaSize = getAreaSize()
    updateBoosts()

    -- Determine control axis: buttons override keyboard/gamepad
    local finalAxis = (buttonAxis ~= nil) and buttonAxis or controlAxis

    -- Player paddle movement (vertical only)
    local playerYPixels = getPaddleYPixels(leftPaddle)
    local playerSpeed = PADDLE_BASE_SPEED * activeBoosts.left.mult
    local moveY = finalAxis * playerSpeed * dt
    playerYPixels = math.clamp(playerYPixels + moveY, 0, areaSize.Y - PADDLE_H)
    setPaddleYPixels(leftPaddle, playerYPixels)

    -- AI paddle: follow ball Y with speed (affected by boost) but with reaction delay and deadzone
    aiReactionTimer = aiReactionTimer - dt
    if aiReactionTimer <= 0 then
        -- set new target with slight inaccuracy
        local jitter = (math.random() * 2 - 1) * AI_JITTER * PADDLE_H
        aiTargetY = math.clamp(ballPos.Y - PADDLE_H/2 + jitter, 0, areaSize.Y - PADDLE_H)
        aiReactionTimer = AI_REACTION_TIME + math.random() * (AI_REACTION_TIME * 0.8)
    end

    local aiYPixels = getPaddleYPixels(rightPaddle)
    local aiSpeed = AI_BASE_SPEED * activeBoosts.right.mult
    if aiTargetY then
        local distance = aiTargetY - aiYPixels
        if math.abs(distance) > AI_DEADZONE then
            local aiMove = math.clamp(distance, -aiSpeed * dt, aiSpeed * dt)
            aiYPixels = aiYPixels + aiMove
        end
    end
    setPaddleYPixels(rightPaddle, aiYPixels)

    -- Ball physics
    ballPos = ballPos + ballVel * ballSpeed * dt
    local radius = BALL_SIZE/2

    -- Top/bottom wall collision
    if ballPos.Y - radius <= 0 then
        ballPos = Vector2.new(ballPos.X, radius)
        ballVel = Vector2.new(ballVel.X, -ballVel.Y)
        pingSound:Play()
        showPing("Ping!", Vector2.new(ballPos.X, ballPos.Y))
    elseif ballPos.Y + radius >= areaSize.Y then
        ballPos = Vector2.new(ballPos.X, areaSize.Y - radius)
        ballVel = Vector2.new(ballVel.X, -ballVel.Y)
        pingSound:Play()
        showPing("Ping!", Vector2.new(ballPos.X, ballPos.Y))
    end

    -- Left paddle collision (improved)
    do
        local px, py, pw, ph = paddleRectPixels(leftPaddle)
        if ballPos.X - radius <= px + pw then
            if ballPos.Y >= py and ballPos.Y <= py + ph then
                -- compute reliable new direction from hit point
                ballPos = Vector2.new(px + pw + radius, ballPos.Y)
                local newDir = reflectFromPaddle("left", px, py, pw, ph)
                ballVel = newDir
                ballSpeed = math.max(ballSpeed * BALL_SPEED_INCREASE, BALL_INITIAL_SPEED * 0.6)
                pingSound:Play()
                showPing("Ping!", Vector2.new(ballPos.X, ballPos.Y))
                lastHit = "left"
            end
        end
    end

    -- Right paddle collision (improved)
    do
        local px, py, pw, ph = paddleRectPixels(rightPaddle)
        if ballPos.X + radius >= px then
            if ballPos.Y >= py and ballPos.Y <= py + ph then
                ballPos = Vector2.new(px - radius, ballPos.Y)
                local newDir = reflectFromPaddle("right", px, py, pw, ph)
                ballVel = newDir
                ballSpeed = math.max(ballSpeed * BALL_SPEED_INCREASE, BALL_INITIAL_SPEED * 0.6)
                pingSound:Play()
                showPing("Ping!", Vector2.new(ballPos.X, ballPos.Y))
                lastHit = "right"
            end
        end
    end

    -- Booster collisions: ball touching booster gives boost to lastHit; paddle touching booster gives boost to that side
    for i = #boosters, 1, -1 do
        local b = boosters[i]
        if not b.frame or not b.frame.Parent then
            table.remove(boosters, i)
        else
            local posPixels = b.pos
            -- Check ball collision
            local dist = (ballPos - posPixels).magnitude
            if dist <= radius + BOOST_RADIUS then
                applyBoost(lastHit, b.type)
                showPing("Boost!", posPixels)
                if b.frame and b.frame.Parent then pcall(function() b.frame:Destroy() end) end
                table.remove(boosters, i)
            else
                -- check left paddle touch
                local px, py, pw, ph = paddleRectPixels(leftPaddle)
                local closestX = math.clamp(posPixels.X, px, px + pw)
                local closestY = math.clamp(posPixels.Y, py, py + ph)
                local d = (Vector2.new(closestX, closestY) - posPixels).magnitude
                if d <= BOOST_RADIUS then
                    applyBoost("left", b.type)
                    showPing("Boost!", posPixels)
                    if b.frame and b.frame.Parent then pcall(function() b.frame:Destroy() end) end
                    table.remove(boosters, i)
                else
                    -- check right paddle touch
                    local px2, py2, pw2, ph2 = paddleRectPixels(rightPaddle)
                    local closestX2 = math.clamp(posPixels.X, px2, px2 + pw2)
                    local closestY2 = math.clamp(posPixels.Y, py2, py2 + ph2)
                    local d2 = (Vector2.new(closestX2, closestY2) - posPixels).magnitude
                    if d2 <= BOOST_RADIUS then
                        applyBoost("right", b.type)
                        showPing("Boost!", posPixels)
                        if b.frame and b.frame.Parent then pcall(function() b.frame:Destroy() end) end
                        table.remove(boosters, i)
                    end
                end
            end
        end
    end

    -- Score check: ball out of left/right
    if ballPos.X + radius < 0 then
        -- right player scores
        rightScoreVal = rightScoreVal + 1
        rightScore.Text = tostring(rightScoreVal)
        resetBall(1)
    elseif ballPos.X - radius > areaSize.X then
        -- left player scores
        leftScoreVal = leftScoreVal + 1
        leftScore.Text = tostring(leftScoreVal)
        resetBall(-1)
    end

    -- Visual update
    setBallPositionPixels(ballPos)
end)

-- Keep UI correctly centered & rescale on screen size change
playFrame:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
    if not alive then return end
    local size = getAreaSize()
    setPaddleYPixels(leftPaddle, math.clamp(getPaddleYPixels(leftPaddle), 0, size.Y - PADDLE_H))
    setPaddleYPixels(rightPaddle, math.clamp(getPaddleYPixels(rightPaddle), 0, size.Y - PADDLE_H))
    setBallPositionPixels(ballPos)
    -- reposition close button relative to playFrame
    closeBtn.Position = UDim2.new(0.5, PLAY_AREA_SIZE.X/2, 0.5, -PLAY_AREA_SIZE.Y/2)
end)


local function applyBoost(side, btype)
    if side ~= "left" and side ~= "right" then return end
    local info = BOOSTS[btype]
    if not info then return end
    activeBoosts[side].mult = info.mult
    activeBoosts[side].endsAt = tick() + BOOST_DURATION
    local lbl = Instance.new("TextLabel", playFrame)
    lbl.Name = side .. "_BoostLabel"
    lbl.Size = UDim2.new(0, 140, 0, 26)
    lbl.Position = side == "left" and UDim2.new(0, 110, 0, 8) or UDim2.new(1, -250, 0, 8)
    lbl.BackgroundTransparency = 0.2
    lbl.BackgroundColor3 = info.color
    lbl.TextColor3 = Color3.new(1, 1, 1)
    lbl.Font = Enum.Font.SourceSansSemibold
    lbl.TextScaled = true
    lbl.Text = info.text
    Instance.new("UICorner", lbl).CornerRadius = UDim.new(0, 6)
    task.spawn(function()
        while activeBoosts[side].endsAt - tick() > 0 and alive do task.wait(0.2) end
        if lbl and lbl.Parent then pcall(function() lbl:Destroy() end) end
    end)
end

local function updateBoosts()
    local now = tick()
    for side, st in pairs(activeBoosts) do
        if st.endsAt > 0 and now >= st.endsAt then
            st.mult = 1; st.endsAt = 0
            local e = playFrame:FindFirstChild(side .. "_BoostLabel")
            if e then pcall(function() e:Destroy() end) end
        end
    end
end


local info = Instance.new("TextLabel", playFrame)
info.Size = UDim2.new(0, 340, 0, 22)
info.Position = UDim2.new(0.5, 0, 1, -30)
info.AnchorPoint = Vector2.new(0.5, 0)
info.BackgroundTransparency = 1
info.TextColor3 = Color3.fromRGB(200,200,200)
info.Font = Enum.Font.SourceSans
info.TextScaled = true
info.Text = "Use joystick vertical or Up/Down keys, or on-screen buttons. Boosters spawn randomly."

-- Close button behavior: clean shutdown
closeBtn.MouseButton1Click:Connect(function()
    if not alive then return end
    alive = false
    -- disconnect render loop
    if renderConn then
        pcall(function() renderConn:Disconnect() end)
        renderConn = nil
    end
    -- destroy GUI safely
    pcall(function() screenGui:Destroy() end)
end)


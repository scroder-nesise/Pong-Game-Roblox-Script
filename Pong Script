-- Helper functions: conversions between UI and pixels
local function getAreaSize()
    local size = playFrame.AbsoluteSize
    if size.X == 0 and size.Y == 0 then
        return PLAY_AREA_SIZE
    end
    return Vector2.new(size.X, size.Y)
end

local function setBallPositionPixels(pos)
    local size = getAreaSize()
    local x = pos.X / size.X
    local y = pos.Y / size.Y
    ball.Position = UDim2.new(x, 0, y, 0)
end

local function getBallPositionPixels()
    local size = getAreaSize()
    local center = ball.Position
    local x = center.X.Scale * size.X + center.X.Offset
    local y = center.Y.Scale * size.Y + center.Y.Offset
    return Vector2.new(x, y)
end

local function setPaddleYPixels(paddleFrame, yPixels)
    local size = getAreaSize()
    local clampedY = math.clamp(yPixels, 0, size.Y - paddleFrame.AbsoluteSize.Y)
    paddleFrame.Position = UDim2.new(paddleFrame.Position.X.Scale, paddleFrame.Position.X.Offset, 0, clampedY)
end

local function getPaddleYPixels(paddleFrame)
    return paddleFrame.Position.Y.Offset
end


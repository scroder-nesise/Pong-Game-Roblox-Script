-- Input handling: joystick vertical axis and keyboard fallback
local controlAxis = 0 -- -1 up, +1 down from keyboard/gamepad
local buttonAxis = nil -- when on-screen buttons pressed: -1 or +1, nil otherwise

-- Keyboard
local function onInputBegan(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.W or input.KeyCode == Enum.KeyCode.Up then
        controlAxis = controlAxis - 1
    elseif input.KeyCode == Enum.KeyCode.S or input.KeyCode == Enum.KeyCode.Down then
        controlAxis = controlAxis + 1
    end
end
local function onInputEnded(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.W or input.KeyCode == Enum.KeyCode.Up then
        controlAxis = controlAxis + 1
    elseif input.KeyCode == Enum.KeyCode.S or input.KeyCode == Enum.KeyCode.Down then
        controlAxis = controlAxis - 1
    end
end
UserInputService.InputBegan:Connect(onInputBegan)
UserInputService.InputEnded:Connect(onInputEnded)

-- Gamepad thumbstick (left stick)
UserInputService.InputChanged:Connect(function(input, gpe)
    if input.UserInputType == Enum.UserInputType.Gamepad1 or input.UserInputType == Enum.UserInputType.Gamepad2 then
        if input.KeyCode == Enum.KeyCode.Thumbstick1 then
            local y = input.Position.Y
            controlAxis = y
        end
    end
end)
UserInputService.GamepadDisconnected:Connect(function()
    controlAxis = 0
end)

-- On-screen buttons handlers
local function setButtonAxis(val)
    buttonAxis = val
end
local function clearButtonAxis()
    buttonAxis = nil
end

local function connectHold(btn, axisVal)
    btn.InputBegan:Connect(function(input)
        if not alive then return end
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            setButtonAxis(axisVal)
        end
    end)
    btn.InputEnded:Connect(function(input)
        if not alive then return end
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            clearButtonAxis()
        end
    end)
    btn.MouseLeave:Connect(function()
        clearButtonAxis()
    end)
end


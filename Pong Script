-- BOOSTERS
-- ──────────────────────────────────────────────
local function createBooster()
    if not alive then return end
    local s = getAreaSize()
    local margin = 80
    local x = math.random(margin, math.max(margin+1, s.X-margin))
    local y = math.random(40, math.max(41, s.Y-40))
    local pos = Vector2.new(x, y)
    local btype = math.random() < 0.5 and "SpeedUp" or "SlowDown"
    local frame = Instance.new("Frame", playFrame)
    frame.Size = UDim2.new(0, BOOST_RADIUS*2, 0, BOOST_RADIUS*2)
    frame.AnchorPoint = Vector2.new(0.5, 0.5)
    frame.Position = UDim2.new(pos.X/s.X, 0, pos.Y/s.Y, 0)
    frame.BackgroundColor3 = BOOSTS[btype].color
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(1, 0)
    local pulse = Instance.new("UIStroke", frame)
    pulse.Color = Color3.fromRGB(255,255,255); pulse.Transparency = 0.75; pulse.Thickness = 1
    table.insert(boosters, { frame = frame, type = btype, pos = pos })
    task.spawn(function()
        local t0 = tick()
        while alive and tick()-t0 < BOOST_LIFETIME do task.wait(0.5) end
        for i = #boosters, 1, -1 do
            if boosters[i].frame == frame then
                if frame and frame.Parent then pcall(function() frame:Destroy() end) end
                table.remove(boosters, i)
            end
        end
    end)
end

task.spawn(function()
    while alive do
        local t = math.random(BOOST_SPAWN_MIN, BOOST_SPAWN_MAX)
        local w = 0
        while alive and w < t do task.wait(0.5); w += 0.5 end
        if alive then createBooster() end
    end
end)

-- ──────────────────────────────────────────────
-- REFLECT
-- ──────────────────────────────────────────────
local function reflectFromPaddle(side, px, py, pw, ph)
    local hit = math.clamp((ballPos.Y - (py + ph/2)) / (ph/2), -1, 1)
    local dirX = side == "left" and 1 or -1
    local dir = Vector2.new(dirX, hit)
    if math.abs(dir.X) < 0.5 then dir = Vector2.new(0.5*dirX, dir.Y) end
    return dir.Unit
end

-- ──────────────────────────────────────────────
-- GAME LOOP
-- ──────────────────────────────────────────────
local aiReactionTimer = 0
local aiTargetY = nil
local lastTime = tick()

local renderConn
renderConn = RunService.RenderStepped:Connect(function()
    if not alive then renderConn:Disconnect() return end

    local now = tick()
    local dt = math.clamp(now - lastTime, 0, 0.05)
    lastTime = now
    areaSize = getAreaSize()
    updateBoosts()
    updateShopEffects()

    shopTitle.Text = "🛒 Shop  (your pts: " .. leftScoreVal .. ")"

    -- Player movement
    local axis = buttonAxis ~= nil and buttonAxis or controlAxis
    local py = getPaddleY(leftPaddle)
    py += axis * PADDLE_BASE_SPEED * activeBoosts.left.mult * dt
    setPaddleY(leftPaddle, py)

    -- AI movement
    aiReactionTimer -= dt
    if aiReactionTimer <= 0 then
        local jitter = (math.random()*2-1) * AI_JITTER * currentPaddleHeights.right
        local targetCenter = ballPos.Y - currentPaddleHeights.right/2 + jitter
        aiTargetY = math.clamp(targetCenter, 0, areaSize.Y - currentPaddleHeights.right)
        aiReactionTimer = AI_REACTION_TIME + math.random() * AI_REACTION_TIME * 0.8
    end

    local aiY = getPaddleY(rightPaddle)
    if aiTargetY then
        local dist = aiTargetY - aiY
        if reverseControlsActive then dist = -dist end
        if math.abs(dist) > AI_DEADZONE then
            aiY += math.clamp(dist, -AI_BASE_SPEED*dt, AI_BASE_SPEED*dt)
        end
    end
    setPaddleY(rightPaddle, aiY)

    -- Ball movement
    ballPos = ballPos + ballVel * ballSpeed * ballGlobalMultiplier * dt
    local r = BALL_SIZE/2

    -- Wall collisions
    if ballPos.Y - r <= 0 then
        ballPos = Vector2.new(ballPos.X, r)
        ballVel = Vector2.new(ballVel.X, -ballVel.Y)
        pingSound:Play()
    elseif ballPos.Y + r >= areaSize.Y then
        ballPos = Vector2.new(ballPos.X, areaSize.Y - r)
        ballVel = Vector2.new(ballVel.X, -ballVel.Y)
        pingSound:Play()
    end

    -- Left paddle collision
    do
        local px, ppy, pw, ph = paddleRect(leftPaddle)
        if ballPos.X - r <= px + pw and ballPos.X - r >= px and ballPos.Y >= ppy and ballPos.Y <= ppy + ph then
            ballPos = Vector2.new(px + pw + r, ballPos.Y)
            ballVel = reflectFromPaddle("left", px, ppy, pw, ph)
            ballSpeed = math.max(ballSpeed * BALL_SPEED_INCREASE, BALL_INITIAL_SPEED * 0.6)
            pingSound:Play()
            showPing("Ping!", ballPos)
            lastHit = "left"
        end
        -- Shield: if ball slips past left paddle, bounce it back once
        if shieldActive and ballPos.X - r < px then
            shieldActive = false
            ballPos = Vector2.new(px + pw + r, ballPos.Y)
            ballVel = Vector2.new(math.abs(ballVel.X), ballVel.Y)
            showPing("🛡 Shield!", ballPos)
        end
    end

    -- Right paddle collision (skipped if ghost ball)
    if not ghostBallActive then
        local px, ppy, pw, ph = paddleRect(rightPaddle)
        if ballPos.X + r >= px and ballPos.X + r <= px + pw + r and ballPos.Y >= ppy and ballPos.Y <= ppy + ph then
            ballPos = Vector2.new(px - r, ballPos.Y)
            ballVel = reflectFromPaddle("right", px, ppy, pw, ph)
            ballSpeed = math.max(ballSpeed * BALL_SPEED_INCREASE, BALL_INITIAL_SPEED * 0.6)
            pingSound:Play()
            showPing("Ping!", ballPos)
            lastHit = "right"
        end
    end

    -- Booster collisions
    for i = #boosters, 1, -1 do
        local b = boosters[i]
        if not b.frame or not b.frame.Parent then
            table.remove(boosters, i)
        elseif (ballPos - b.pos).Magnitude <= r + BOOST_RADIUS then
            applyBoost(lastHit, b.type)
            showPing("Boost!", b.pos)
            pcall(function() b.frame:Destroy() end)
            table.remove(boosters, i)
        end
    end

    -- Scoring with difficulty bonus
    if ballPos.X + r < 0 then
        rightScoreVal += 1
        rightScore.Text = tostring(rightScoreVal)
        resetBall(1)
    elseif ballPos.X - r > areaSize.X then
        local diffBonus = currentDifficulty == "Easy" and 1 or currentDifficulty == "Medium" and 2 or 3
        local pts = doublePointsActive and diffBonus * 2 or diffBonus
        leftScoreVal += pts
        leftScore.Text = tostring(leftScoreVal)
        showPing("+" .. pts .. "!", Vector2.new(areaSize.X/2, areaSize.Y/2))
        resetBall(-1)
    end

    setBallPos(ballPos)
end)


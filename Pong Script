local function resetBall(dir)
    local s = getAreaSize()
    ballPos = Vector2.new(s.X/2, s.Y/2)
    local vy = (math.random()*2 - 1) * 0.35
    local vx = dir or (math.random() > 0.5 and 1 or -1)
    ballVel = Vector2.new(vx, vy).Unit
    ballSpeed = BALL_INITIAL_SPEED
    setBallPos(ballPos)
end
resetBall(-1)

